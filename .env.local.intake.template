# Intake-specific env vars — merge these into .env.local
#
# Run `netlify dev` from this directory to start the full stack
# (Next.js + Netlify Edge for /api/intake/chat + Netlify Functions for
# /api/intake/state and /api/intake/transcribe). `netlify dev` reads
# .env.local automatically.

# Anthropic API key — used by the intake chat edge function.
# Get from https://console.anthropic.com/.
ANTHROPIC_API_KEY=

# Supabase service-role key — server-side write access to
# finit_intake_sessions. NEVER expose to the browser.
# Supabase Dashboard → Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Supabase project URL (Voicelink project, where finit_intake_sessions lives).
# The edge function tries SUPABASE_URL first, falls back to NEXT_PUBLIC_SUPABASE_URL.
SUPABASE_URL=https://mffnzuklxjwoprdiviyr.supabase.co
NEXT_PUBLIC_SUPABASE_URL=https://mffnzuklxjwoprdiviyr.supabase.co

# Optional — only for testing the voice-input flow in ask_long_text_voice.
ELEVENLABS_API_KEY=

# logo.dev publishable token — used by the system_picker widget to
# render company logos. Safe in the browser (publishable, rate-limited
# per referer, not a secret). Get from https://logo.dev/dashboard.
# If unset, logos still load but unauthenticated (lower rate limit).
NEXT_PUBLIC_LOGO_DEV_TOKEN=
