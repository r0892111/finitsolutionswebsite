# Finit OS interactive intake — env vars
# Copy to .env.local (or set in Netlify Dashboard → Environment variables) before running.
# Never commit real keys.

# --- Anthropic (chat agent) ---
ANTHROPIC_API_KEY=

# --- Supabase (intake state store) ---
# SUPABASE_URL is the same project URL as NEXT_PUBLIC_SUPABASE_URL — duplicated
# here so the server-only intake code never has to fall back to the public
# var. The SERVICE_ROLE_KEY is server-only; never expose to the browser.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- ElevenLabs (speech-to-text for voice answers) ---
ELEVENLABS_API_KEY=

# --- GitHub (paying-client repo commits on intake submit) ---
# Fine-grained PAT scoped to the Finit OS GitHub org with Contents:write on
# the client repos that the intake flow needs to touch. Never use a personal
# PAT — short-lived service tokens only.
GITHUB_TOKEN=
INTAKE_GITHUB_OWNER=finit-os

# --- Email (transactional sends from /api/intake/submit) ---
# Resend is the default email transport — see lib/intake/mini-report.ts.
# Swap to Postmark / Mailgun by editing that file; Gmail-via-gws is explicitly
# NOT used here (DRAFT-only rule per global CLAUDE.md).
RESEND_API_KEY=
RESEND_FROM="Finit <hello@finitsolutions.be>"

# --- Operator-facing config ---
INTAKE_OPERATOR_EMAIL=alex@finitsolutions.be
# Calendly link for the lead-magnet upsell CTA in the mini-report.
CALENDLY_URL=https://calendly.com/finit-karel/30min

# --- Existing Supabase (web app already uses these) ---
# Leaving here for completeness; the intake routes prefer the server-only
# pair above (SUPABASE_URL + SERVICE_ROLE_KEY) but fall back to NEXT_PUBLIC_*
# if needed.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
